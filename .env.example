# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=codebase
QDRANT_VECTOR_SIZE=768

# Redis Stack
REDIS_URL=redis://localhost:6379
CACHE_EXACT_TTL_SECONDS=3600
CACHE_SEMANTIC_TTL_SECONDS=1800
CACHE_SEMANTIC_THRESHOLD=0.92

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder:6.7b
OLLAMA_TIMEOUT_SECONDS=120

# Embedding model (loaded via sentence-transformers)
EMBED_MODEL_NAME=nomic-ai/nomic-embed-code
EMBED_BATCH_SIZE=32
EMBED_DEVICE=cpu

# Reranking
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

# Chunking
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
CONTEXT_TOKEN_BUDGET=3000

# Ingestion
SQLITE_DB_PATH=data/tracking.db
REPOS_BASE_DIR=data/repos
